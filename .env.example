# Linear API Key - Get from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# GitHub Organization
GITHUB_ORG=ruh-ai

# Base branch to create PRs against
TARGET_BRANCH=dev

# Directory to clone/manage repos
REPOS_DIR=./repos

# Log directory
LOGS_DIR=./logs

# Poll interval in minutes (default: 60)
POLL_INTERVAL_MINUTES=60
